# WebDAV base URL (no trailing path):
#   European region:  https://ewebdav.pcloud.com
#   Other regions:    https://webdav.pcloud.com
PCLOUD_WEBDAV_URL=https://ewebdav.pcloud.com
PCLOUD_USERNAME=your_email@example.com
PCLOUD_PASSWORD=your_password
DB_PATH=/app/data/photos.db

# Optional: CLIP cosine similarity threshold (0–1) for “Common in your library” tag counts
# TAG_SIMILARITY_THRESHOLD=0.27
