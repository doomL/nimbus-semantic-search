# WebDAV base URL (no trailing path):
#   European region:  https://ewebdav.pcloud.com
#   Other regions:    https://webdav.pcloud.com
PCLOUD_WEBDAV_URL=https://ewebdav.pcloud.com
PCLOUD_USERNAME=your_email@example.com
PCLOUD_PASSWORD=your_password
DB_PATH=/app/data/photos.db

# Optional: CLIP cosine similarity threshold (0–1) for “Common in your library” tag counts
# TAG_SIMILARITY_THRESHOLD=0.27

# Optional: lock the whole app (UI + API) when exposed on the internet — HTTP Basic Auth
# NIMBUS_AUTH_USER=you
# NIMBUS_AUTH_PASSWORD=use_a_long_random_secret

# Optional: periodic server-side index (e.g. daily). Indexing runs in the background; close the browser anytime.
# NIMBUS_AUTO_INDEX_INTERVAL_HOURS=24
# Minutes to wait after container start before the first auto run (default 5)
# NIMBUS_AUTO_INDEX_FIRST_DELAY_MINUTES=5
